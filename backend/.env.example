# Copy this file to .env and fill in all values before starting the backend.

# ── Database ────────────────────────────────────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///./backend/trading_saas.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/goldsignal

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_random_64_char_hex_string

# ── NOWPayments ──────────────────────────────────────────────────────────────
# Get from: https://nowpayments.io/dashboard
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
# IPN secret — set in NOWPayments dashboard under "Store settings > IPN secret"
NOWPAYMENTS_IPN_SECRET=your_ipn_secret

# ── Internal signal secret ───────────────────────────────────────────────────
# Shared between 07_trading_logic.py and the backend.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_SIGNAL_SECRET=CHANGE_ME_another_random_secret

# ── Subscription ─────────────────────────────────────────────────────────────
SUBSCRIPTION_PRICE_USD=50.0
SUBSCRIPTION_DAYS=30

# ── Public URL (used in webhook callbacks and dashboard links) ────────────────
BASE_URL=https://your-domain.com
